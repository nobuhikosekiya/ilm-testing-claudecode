# Copy this file to .env_v8.19 (or .env_v9.4) and fill in real values.
# NEVER commit the filled-in file — it is covered by .gitignore.
#
# ES_URL: your Elastic Cloud cluster endpoint
#   e.g. https://<cluster-id>.es.<region>.gcp.cloud.es.io
#
# API_KEY: a base64-encoded Elasticsearch API key with at minimum:
#   cluster privileges: monitor, manage_ilm, manage_slm
#   index privileges: all (or manage, write, read) on the test data stream
#
# Generate one in Kibana → Stack Management → API Keys, or via:
#   POST /_security/api_key
#   { "name": "ilm-test", "role_descriptors": {
#       "ilm_tester": {
#         "cluster": ["monitor","manage_ilm","manage_slm","manage_index_templates"],
#         "indices": [{"names":["*"],"privileges":["all"]}]
#       }
#   }}

ES_URL="https://your-cluster-id.es.region.gcp.cloud.es.io"
API_KEY="your_base64_api_key_here"
